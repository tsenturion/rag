FROM python:3.13.14-slim@sha256:eb43ff125d8d58d7449dcba7d336c23bcac412f526d861db493b9994d8010280

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

RUN groupadd --system runner \
    && useradd --system --gid runner --home /home/runner runner

COPY requirements-code-runner.txt ./
RUN python -m pip install --upgrade pip \
    && python -m pip install --requirement requirements-code-runner.txt

COPY src/code_runner ./code_runner

USER runner

EXPOSE 8010

HEALTHCHECK --interval=15s --timeout=3s --start-period=5s --retries=5 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8010/health', timeout=2)"

CMD ["uvicorn", "code_runner.app:app", "--host", "0.0.0.0", "--port", "8010", "--workers", "1"]
