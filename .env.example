# Ключ OpenAI нужен для embeddings и агента.
OPENAI_API_KEY=sk-...

# Ключ OpenWeatherMap нужен для weather tool агента.
OPENWEATHER_API_KEY=...

# Authorization key GigaChat нужен для agent_gigachat и embeddings_gigachat.
GIGACHAT_AUTH_KEY=...

# Токен Hugging Face нужен для скачивания локальных LLM без anonymous rate limit.
HF_TOKEN=hf_...

# Сервисный ключ для Docker/API support-агента.
SUPPORT_SERVICE_API_KEY=change-me

# Необязательный HMAC secret для Bearer JWT и ролевого доступа к API.
SUPPORT_JWT_SECRET=replace-with-at-least-32-random-characters

# Учётная запись локальной Grafana из Compose-профиля observability.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-random-secret

# Внутренний ключ между support-agent и изолированным code-runner.
CODE_RUNNER_API_KEY=change-code-runner-secret

# Выбирает provider-конфиг support-сервиса внутри Docker Compose.
SUPPORT_AGENT_CONFIG=

# Публичная основа ссылок в A2A Agent Card за reverse proxy/Kubernetes.
# Для локального запуска используйте http://127.0.0.1:8000.
SUPPORT_PUBLIC_BASE_URL=http://127.0.0.1:8000

# Выбирает набор готовых embeddings для загрузки в Qdrant server.
VECTOR_STORE_CONFIG=

# Учётные данные локального RabbitMQ для orchestration-профилей Docker Compose.
RABBITMQ_DEFAULT_USER=rag
RABBITMQ_DEFAULT_PASS=replace-with-random-secret

# Число процессов Celery worker. Для local LLM оставьте 1.
ORCHESTRATION_WORKER_CONCURRENCY=2

# Эти адреса используются при запуске worker/CLI на хосте, вне Docker.
ORCHESTRATION_BROKER_URL=amqp://rag:replace-with-random-secret@127.0.0.1:5672//
ORCHESTRATION_RESULT_BACKEND_URL=redis://127.0.0.1:6379/1
ORCHESTRATION_REDIS_URL=redis://127.0.0.1:6379/0

# Локальная Camunda из compose-профиля bpmn не требует API-аутентификации.
CAMUNDA_REST_ADDRESS=http://127.0.0.1:8088/v2
CAMUNDA_AUTH_STRATEGY=NONE
