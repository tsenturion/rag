# Ключ OpenAI нужен для embeddings и агента.
OPENAI_API_KEY=sk-...

# Ключ OpenWeatherMap нужен для weather tool агента.
OPENWEATHER_API_KEY=...

# Authorization key GigaChat нужен для agent_gigachat и embeddings_gigachat.
GIGACHAT_AUTH_KEY=...

# Токен Hugging Face нужен для скачивания локальных LLM без anonymous rate limit.
HF_TOKEN=hf_...

# Сервисный ключ для Docker/API support-агента.
SUPPORT_SERVICE_API_KEY=change-me

# Внутренний ключ между support-agent и изолированным code-runner.
CODE_RUNNER_API_KEY=change-code-runner-secret

# Выбирает provider-конфиг support-сервиса внутри Docker Compose.
SUPPORT_AGENT_CONFIG=

# Выбирает набор готовых embeddings для загрузки в Qdrant server.
VECTOR_STORE_CONFIG=
